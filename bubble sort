#include <iostream>
#include <vector>

// Function to perform Bubble Sort on a vector
void bubbleSort(std::vector<int>& arr) {
    int n = arr.size();
    bool swapped;
    
    // Outer loop runs for each pass
    for (int i = 0; i < n - 1; ++i) {
        swapped = false;
        
        // Inner loop compares adjacent elements
        for (int j = 0; j < n - i - 1; ++j) {
            // Swap if the current element is greater than the next
            if (arr[j] > arr[j + 1]) {
                std::swap(arr[j], arr[j + 1]);
                swapped = true; // Mark that a swap occurred
            }
        }
        
        // Optimization: If no elements were swapped, the array is already sorted
        if (!swapped) {
            break;
        }
    }
}

// Function to print the vector elements
void printArray(const std::vector<int>& arr) {
    for (int num : arr) {
        std::cout << num << " ";
    }
    std::cout << "\n";
}

int main() {
    std::vector<int> data = {64, 34, 25, 12, 22, 11, 90};
    
    std::cout << "Original Array:\n";
    printArray(data);
    
    bubbleSort(data);
    
    std::cout << "Sorted Array in Ascending Order:\n";
    printArray(data);
    
    return 0;
}
